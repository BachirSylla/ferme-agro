# Copie ce fichier vers .env.local et renseigne tes vraies valeurs.
# .env.local est gitignore — n'y mets jamais de secret en clair dans .env.example.

# URL de l'API Supabase
#  - dev local : http://localhost:54321
#  - prod      : https://<project-ref>.supabase.co
VITE_SUPABASE_URL=http://localhost:54321

# Clé publique "anon" (publishable). Sécurité = RLS, pas le secret de la clé.
# Récupère-la avec `supabase status` (local) ou dans Project Settings → API (prod).
VITE_SUPABASE_ANON_KEY=

# Feature flag : true pour rouvrir l'inscription publique sur l'écran d'auth.
# Le code d'inscription reste en place et fonctionnel quel que soit ce flag —
# il pilote seulement l'affichage des onglets "Connexion / Créer un compte".
# Décommente la ligne pour rallumer.
# VITE_ALLOW_PUBLIC_SIGNUP=true
